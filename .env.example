# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control — it is listed in .gitignore.

# ─── Vercel Analytics (add after deploying) ────────────────────────────────────
VITE_VERCEL_ANALYTICS_ID=your_analytics_id

# ─── Future: AI API Key ────────────────────────────────────────────────────────
# Required for Alberta Program Finder and Cloud Cost Explainer projects
VITE_AI_API_KEY=your_api_key_here

# ─── EmailJS — Contact Form (add when building Contact section) ────────────────
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
